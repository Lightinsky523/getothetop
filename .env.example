# ===== 服务器配置 =====
PORT=3000
NODE_ENV=production

# ===== 管理员密码（必须设置，至少12位） =====
ADMIN_PASSWORD=your-very-strong-password-here-12chars+

# ===== MySQL 数据库（无默认值，必须配置） =====
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=ycyz_db

# ===== 跨域白名单（生产环境必须配置，逗号分隔） =====
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===== AI 服务 =====
# 智能查询（Stepfun 阶跃星辰）
STEPFUN_API_KEY=your-stepfun-api-key
STEPFUN_MODEL=step-3.5-flash
STEPFUN_VECTOR_STORE_ID=

# 百炼（学生证鉴伪 + 内容审核）
BAILIAN_API_KEY=your-bailian-api-key
DIRECT_AI_KEY=
DASHSCOPE_VISION_MODEL=qwen-vl-plus

# 数据检索录入（DeepSeek）
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# ===== 邮件 SMTP（邮箱验证码） =====
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password-or-auth-code
SMTP_FROM=your-email@example.com

# ===== 阿里云内容安全（可选） =====
ALIYUN_ACCESS_KEY_ID=your-access-key
ALIYUN_ACCESS_KEY_SECRET=your-access-secret
ALIYUN_GREEN_REGION=cn-shanghai

# ===== 数据持久化（魔搭创空间 / 本地） =====
DATA_DIR=/home/user/app/data
DATASET_MOUNT_PATH=
AUTO_CLONE_DATASET=
DATASET_LOCAL_PATH=

# ===== 可选：请求体大小限制 =====
BODY_LIMIT=250mb
